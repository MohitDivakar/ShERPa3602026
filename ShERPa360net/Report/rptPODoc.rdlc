            <Style>
              <TextAlign>Left</TextAlign>
            </Style>
          </Paragraph>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>Note: All invoices must be submitted by the vendor by email to </Value>
                <Style>
                  <FontFamily>Tahoma</FontFamily>
                  <FontSize>9pt</FontSize>
                  <FontWeight>Normal</FontWeight>
                  <Color>#4d4d4d</Color>
                </Style>
              </TextRun>
              <TextRun>
                <Value>billdesk@qarmatek.com</Value>
                <Style>
                  <FontFamily>Tahoma</FontFamily>
                  <FontSize>9pt</FontSize>
                  <FontWeight>Bold</FontWeight>
                  <Color>#4d4d4d</Color>
                </Style>
              </TextRun>
              <TextRun>
                <Value> to initiate processing.  Payments will be made ONLY on the basis of original invoices, duly approved, with complete supporting documents.</Value>
