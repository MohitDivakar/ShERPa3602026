                            <TextRun>
                              <Value>=Fields!ITEMDESCRIPTION.Value + "(" + Fields!ITEMCODE.Value +")" 
+ iif(Fields!ITEMTEXT.Value&lt;&gt;"", vbcrlf + Fields!ITEMTEXT.Value,"") 
+ iif(Fields!IMEINO.Value &lt;&gt; "" ,vbcrlf + Fields!IMEINO.Value,"")</Value>
                              <Style>
