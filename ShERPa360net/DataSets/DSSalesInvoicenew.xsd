          <TableAdapter BaseClass="System.ComponentModel.Component" DataAccessorModifier="AutoLayout, AnsiClass, Class, Public" DataAccessorName="DSSITAXTableAdapter" GeneratorDataComponentClassName="DSSITAXTableAdapter" Name="DSSITAX" UserDataComponentName="DSSITAXTableAdapter">
            <MainSource>
              <DbSource ConnectionRef="ConnStringSherpa (Web.config)" DbObjectName="SELECT A.CMPID, A.SINO, MAX(A.RATE) AS AVGRATE, SUM(A.TAXAMT) AS AVGAMT FROM TRAN_SICOND AS A WITH (NOLOCK) WHERE A.CMPID = @CMPID AND (A.SINO = @SINO) AND A.TAXAMT &gt; 0 GROUP BY A.CMPID, A.SINO, A.CONDID" DbObjectType="Unknown" FillMethodModifier="Public" FillMethodName="Fill" GenerateMethods="Both" GenerateShortCommands="false" GeneratorGetMethodName="GetData" GeneratorSourceName="Fill" GetMethodModifier="Public" GetMethodName="GetData" QueryType="Rowset" ScalarCallRetval="System.Object, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" UseOptimisticConcurrency="false" UserGetMethodName="GetData" UserSourceName="Fill">
                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT S.AVGRATE , S.AVGAMT, MAX(X.STATEID) AS CUSTSTATE, MAX(W.STCD) AS VENDSTATE FROM (
					SELECT A.CMPID, A.SINO, MAX(A.RATE) AS AVGRATE, SUM(A.TAXAMT) AS AVGAMT
					FROM TRAN_SICOND AS A WITH(NOLOCK)
					WHERE  A.CMPID = @CMPID AND  (A.SINO = @SINO)  AND A.TAXAMT &gt; 0 GROUP BY A.CMPID, A.SINO, A.CONDID
					) AS S 
					LEFT OUTER JOIN TRAN_SIMST AS T WITH(NOLOCK) ON S.CMPID = T.CMPID AND S.SINO = T.SINO
					LEFT OUTER JOIN TRAN_SOMST AS X WITH(NOLOCK) ON T.CMPID = X.CMPID AND T.SONO = X.SONO
					LEFT OUTER JOIN VIE_SIDTL AS U WITH(NOLOCK) ON S.CMPID = U.CMPID AND S.SINO = U.SINO
					LEFT OUTER JOIN MST_PLANT AS V WITH(NOLOCK) ON U.PLANTCD = V.PLANTCD
					LEFT OUTER JOIN MST_ADDRESS AS W WITH(NOLOCK) ON V.ADDID = W.ID
					GROUP BY S.AVGRATE, S.AVGAMT</CommandText>
                    <Parameters>
                      <Parameter AllowDbNull="false" AutogeneratedName="CMPID" ColumnName="" DataSourceName="" DataTypeServer="numeric(18, 0)" DbType="Decimal" Direction="Input" ParameterName="@CMPID" Precision="18" Scale="0" Size="9" SourceColumn="" SourceColumnNullMapping="false" SourceVersion="Current" />
                      <Parameter AllowDbNull="false" AutogeneratedName="SINO" ColumnName="" DataSourceName="" DataTypeServer="nvarchar(10)" DbType="String" Direction="Input" ParameterName="@SINO" Precision="0" Scale="0" Size="10" SourceColumn="" SourceColumnNullMapping="false" SourceVersion="Current" />
                    </Parameters>
                  </DbCommand>
                </SelectCommand>
              </DbSource>
