        <Tables>
          <TableAdapter BaseClass="System.ComponentModel.Component" DataAccessorModifier="AutoLayout, AnsiClass, Class, Public" DataAccessorName="DSSITableAdapter" GeneratorDataComponentClassName="DSSITableAdapter" Name="DSSI" UserDataComponentName="DSSITableAdapter">
            <MainSource>
              <DbSource ConnectionRef="ConnStringSherpa (Web.config)" DbObjectType="Unknown" FillMethodModifier="Public" FillMethodName="Fill" GenerateMethods="Both" GenerateShortCommands="false" GeneratorGetMethodName="GetData" GeneratorSourceName="Fill" GetMethodModifier="Public" GetMethodName="GetData" QueryType="Rowset" ScalarCallRetval="System.Object, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" UseOptimisticConcurrency="false" UserGetMethodName="GetData" UserSourceName="Fill">
                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT  ISNULL(CASE WHEN H.ITEMGRPID = 9 THEN (C.PRODMAKE + ' ' + B.MODELDESC + ' ' + B.RAMSIZE +' GB ' + B.ROMSIZE +' GB ' + B.COLOR) ELSE H.ITEMDESC END,H.ITEMDESC) AS ITEMSPEC , E.HSNCODE,
					F.RETAILCUSTNAME AS ENDCUST,F.CUSTADD1 AS ENDADDR1,F.CUSTADD2 AS ENDADDR2,F.CUSTADD3 AS ENDADDR3,F.CITY AS ENDCITY,F.STATE AS ENDSTATE,F.CUSTMOBILENO AS ENDMOBILENO,
					F.PINCODE AS ENDPOSTALCODE,C.PRODMAKE,C.PRODMODEL,F.CUSTPARTDESC2 AS IMEINO, H.JOBID,C.JOBDT,H.ITEMDESC,G.TAXAMT,H.SINO,F.CMPID,H.QTY,
					CASE WHEN A.SITYPE = 'SLR' THEN (H.RATE - H.DISCAMT) ELSE H.RATE END AS RATE,
					CAST(((CASE WHEN A.SITYPE = 'SLR' THEN (H.RATE - H.DISCAMT) ELSE H.RATE END) * H.QTY) AS DECIMAL(10,2)) AS CAMOUNT,
					A.SIDT,H.DISCAMT,A.OTHERS,A.NETAMT,A.TOTAMT,A.ROUNDOFF,ISNULL(G.RATE, 0) AS TAXRATE,A.REMARK,H.SITYPE AS SITYPE,A.COUPONNO, H.COUPONVALUE,G.CONDTYPE,A.TAXOTH,A.TAXDISC,B.SERIALNO,
					I.PAYMODE,J.DESCR,A.PREPAIDAMT,A.REMAINAMT,UPPER(K.ADDOF) AS ADDOF,L.ADDR1,L.ADDR2,L.ADDR3,L.CITY,L.POSTALCODE,K.GSTNO,M.STATE,M.STATECODE,O.ADDR1 AS DISPADDR1,O.ADDR2 AS DISPADDR2,
					O.ADDR3 AS DISPADDR3,O.CITY AS DISPCITY,O.POSTALCODE AS DISPPOSTALCODE,P.STATE AS DISPSTATE,P.STATECODE AS DISPSTATECODE,F.REFNO,F.GSTNO AS CUSTGSTNO,F.RETAILCUSTNAME AS CUSTNAME,
					F.CUSTADD1,F.CUSTADD2,F.CUSTADD3,F.CITY AS SOCITY,F.PINCODE,F.STATE  AS SOSTATE,H.ITEMGRPID,A.NETTAXAMT,A.SITYPE,F.SEGMENT,N.GSTNO AS DISPATCHGST,F.PLANTCD,F.EWID,F.EWDESC,F.EWPRICE
					FROM VIE_SODTL AS F WITH(NOLOCK) 
					LEFT OUTER JOIN VIE_JOBSHEET AS C WITH(NOLOCK) ON F.JOBID = C.JOBID
					LEFT OUTER JOIN VIE_DCSODTL AS Q WITH(NOLOCK) ON F.SONO = Q.SONO AND F.SRNO = Q.SOSRNO
					LEFT OUTER JOIN VIE_SIDTL AS H WITH(NOLOCK) ON H.SONO = F.SONO  AND Q.DOCNO = H.DCNO AND Q.SRNO = H.DCSRNO
					LEFT OUTER JOIN TRAN_SIMST AS A WITH(NOLOCK) ON A.SINO = H.SINO
					LEFT OUTER JOIN TRAN_JSPROD_SPEC AS B WITH(NOLOCK) ON H.JOBID = B.JOBID
					LEFT OUTER JOIN MST_ITEM AS D WITH(NOLOCK) ON H.ITEMID = D.ITEMID
					LEFT OUTER JOIN MST_ITEMSUBGRP AS E WITH(NOLOCK) ON E.ID = D.ITEMSUBGRP
					LEFT OUTER JOIN TRAN_SICOND AS G WITH(NOLOCK) ON H.CMPID = G.CMPID AND H.SINO = G.SINO AND H.SRNO = G.SISRNO 
					LEFT OUTER JOIN MST_PAYMENTMODE AS I WITH(NOLOCK) ON F.PAYMODE = I.ID
					LEFT OUTER JOIN MST_PAYTERMS AS J WITH(NOLOCK) ON F.PMTTERMS = J.PMTTERMS
					LEFT OUTER JOIN MST_PLANT AS K WITH(NOLOCK) ON K.CMPID = F.CMPID AND K.PLANTCD = H.PLANTCD
					LEFT OUTER JOIN MST_ADDRESS AS L WITH(NOLOCK) ON L.CMPID = K.CMPID AND L.ID = K.GSTADDID
					LEFT OUTER JOIN MST_STATE AS M WITH(NOLOCK) ON M.ID = L.STCD
					LEFT OUTER JOIN MST_PLANT AS N WITH(NOLOCK) ON N.CMPID = F.CMPID AND N.PLANTCD = H.PLANTCD
					LEFT OUTER JOIN MST_ADDRESS AS O WITH(NOLOCK) ON O.CMPID = N.CMPID AND O.ID = N.ADDID
					LEFT OUTER JOIN MST_STATE AS P WITH(NOLOCK) ON P.ID = O.STCD
					WHERE H.CMPID = @CMPID AND H.SINO = @SINO  ORDER BY TAXRATE DESC</CommandText>
                    <Parameters>
                      <Parameter AllowDbNull="false" AutogeneratedName="CMPID" ColumnName="CMPID" DataSourceName="SHERPADB.dbo.VIE_SIDTL" DataTypeServer="numeric(18, 0)" DbType="Decimal" Direction="Input" ParameterName="@CMPID" Precision="18" ProviderType="Decimal" Scale="0" Size="9" SourceColumn="CMPID" SourceColumnNullMapping="false" SourceVersion="Current" />
